  <style>
    /* ===== Fade-in on scroll ===== */
    .reveal{
      opacity:0;
      transform:translateY(14px);
      transition:
        opacity .7s cubic-bezier(.22,.61,.36,1) var(--d,0s),
        transform .7s cubic-bezier(.22,.61,.36,1) var(--d,0s);
      will-change: opacity, transform;
    }
    .reveal.is-inview{ opacity:1; transform:none; }
    @media (prefers-reduced-motion: reduce){
      .reveal, .reveal.is-inview{ opacity:1 !important; transform:none !important; transition:none !important; }
    }

    /* Section */
    .projects { background: #1b1a1b; padding: 56px 0; }
    .container { max-width: 1120px; margin: 0 auto; padding: 0 16px; }
    @media (min-width: 640px) { .container { padding: 0 24px; } }
    @media (min-width: 1024px) { .container { padding: 0 32px; } }

    /* Heading */
    .heading { text-align: center; margin-bottom: 24px; }
    .title { color: #fff; margin: 0; }
    .subhead { color: #cfcfcf; margin-top: 8px; }

    /* Item layout */
    .item {
      display: grid;
      gap: 18px;
      grid-template-columns: 1fr;      /* mobile stack */
      align-items: center;
      margin-bottom: 36px;
    }
    @media (min-width: 900px) {
      .item { grid-template-columns: 1.1fr 1fr; gap: 28px; margin-bottom: 56px; }
      .item.item--alt .media { order: 2; }
      .item.item--alt .content { order: 1; }
    }

    /* Image card */
    .shot {
      background: #0d0f10;
      border-radius: 14px;
      border: 1px solid rgba(255,255,255,0.08);
      box-shadow: 0 18px 48px rgba(0,0,0,0.45);
      overflow: hidden;
    }
    .shot img { display: block; width: 100%; height: auto; }

    /* Content */
    .content { color: #e6e6e6; }
    .desc { color: #bdbdbd; margin-top: 8px; }

    /* Tag chips */
    .tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 8px; }
    .tag {
      display: inline-flex; align-items: center;
      padding: 6px 10px; border-radius: 999px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.12);
      color: #cfcfcf; white-space: nowrap;
    }

    /* Per-project link (text only) */
    .actions { margin-top: 10px; }
    .visit-link {
      color: #cfcfcf;
      text-decoration: underline;
      text-underline-offset: 3px;
      transition: opacity .2s ease;
    }
    .visit-link:hover { opacity: .85; }

    /* Bottom CTA button */
    .cta { display: flex; justify-content: center; margin-top: 8px; }
    .btn {
      display: inline-flex; align-items: center; justify-content: center;
      padding: 12px 18px; border-radius: 10px; text-decoration: none;
      border: 1px solid transparent;
    }
    .btn-primary {
      background: #d9d9d9; color: #000; border-color: #d9d9d9;
      box-shadow: 0 10px 24px rgba(0,0,0,0.35);
      letter-spacing: .04em;
    }
    .btn-primary:hover { filter: brightness(0.95); }

    /* Tight mobile spacing */
    @media (max-width: 420px) {
      .tag { padding: 5px 9px; }
      .desc { margin-top: 6px; }
      .actions { margin-top: 8px; }
    }
  </style>

  <!-- Tiny, section-scoped JS to toggle .is-inview one-by-one -->
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var section = document.getElementById('projects');
      if (!section) return;

      // Observe all .reveal elements inside this section
      var toReveal = section.querySelectorAll('.reveal');

      if (!('IntersectionObserver' in window)) {
        for (var i = 0; i < toReveal.length; i++) toReveal[i].classList.add('is-inview');
        return;
      }

      var io = new IntersectionObserver(function (entries) {
        // Sort entries by vertical position so they fade in top-to-bottom when multiple appear at once
        entries.sort(function (a, b) {
          return (a.target.getBoundingClientRect().top) - (b.target.getBoundingClientRect().top);
        });

        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-inview');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -10% 0px' });

      for (var i = 0; i < toReveal.length; i++) io.observe(toReveal[i]);
    });
  </script>
</section>
